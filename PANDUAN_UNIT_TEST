### D. Test Database Transaction
```php
public function testWithDatabaseTransaction()
{
    // Setup transaction expectations
    DB::shouldReceive('beginTransaction')->once();
    DB::shouldReceive('commit')->once();
    DB::shouldReceive('rollback')->never();
    
    // Act & Assert
    $result = $service->doSendAkadAgunan($refno, $rekening);
    $this->assertTrue($result);
}

// Test error dengan rollback
public function testTransactionRollbackOnError()
{
    DB::shouldReceive('beginTransaction')->once();
    DB::shouldReceive('rollback')->once();
    DB::shouldReceive('commit')->never();
    
    $this->eksternalservice->shouldReceive('kirimAkadSIKP')
        ->andThrow(new Exception("Error"));
    
    $this->expectException(Exception::class);
    $service->doSendAkadAgunan($refno, $rekening);
}
```

