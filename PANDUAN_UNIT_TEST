## 13. 📚 Contoh Template Lengkap

```php
<?php

declare(strict_types=1);

namespace Tests\Unit\Usecases;

use App\Models\Prakarsa;
use App\Repositories\PrakarsaRepository;
use App\Services\ExternalService;
use App\Usecases\MyUsecase;
use Exception;
use Mockery;
use PHPUnit\Framework\TestCase;
use Spotlibs\PhpLib\Exceptions\DataNotFoundException;

/**
 * @coversDefaultClass \App\Usecases\MyUsecase
 */
class MyUsecaseTest extends TestCase
{
    private $prakarsaRepo;
    private $externalService;

    protected function setUp(): void
    {
        parent::setUp();
        $this->prakarsaRepo = Mockery::mock(PrakarsaRepository::class);
        $this->externalService = Mockery::mock(ExternalService::class);
    }

    protected function tearDown(): void
    {
        \Mockery::close();
        parent::tearDown();
    }

    protected function makeService()
    {
        return Mockery::mock(MyUsecase::class, [
            $this->prakarsaRepo,
            $this->externalService,
        ])->makePartial();
    }

    /**
     * @covers ::doSomething
     */
    public function testDoSomethingReturnsTrue()
    {
        // ARRANGE
        $prakarsa = new Prakarsa(['refno' => 'REF001']);
        
        $this->prakarsaRepo->shouldReceive('getPrakarsa')
            ->once()
            ->with('REF001')
            ->andReturn($prakarsa);

        $this->externalService->shouldReceive('send')
            ->once()
            ->andReturn(true);

        // ACT
        $service = $this->makeService();
        $result = $service->doSomething('REF001');

        // ASSERT
        $this->assertTrue($result);
    }

    /**
     * @covers ::doSomething
     */
    public function testDoSomethingThrowExceptionWhenNotFound()
    {
        // ARRANGE
        $this->expectException(DataNotFoundException::class);
        
        $this->prakarsaRepo->shouldReceive('getPrakarsa')
            ->once()
            ->andReturn(null);

        // ACT
        $service = $this->makeService();
        $service->doSomething('INVALID_REF');

        // ASSERT is implicit via expectException
    }
}
```

