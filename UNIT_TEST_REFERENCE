## Test Method Template (AAA Pattern)

```php
/**
 * @covers ::methodName
 * @covers ::helperMethod
 */
public function testMethodNameScenarioExpectedResult()
{
    // ========== ARRANGE ==========
    // Setup test data & mock expectations
    $testData = new Model(['key' => 'value']);
    
    $this->dependency->shouldReceive('method')
        ->once()
        ->with('expected_arg')
        ->andReturn($testData);
    
    $this->otherDep->shouldReceive('action')
        ->andThrow(new Exception('Error'));
    
    // ========== ACT ==========
    // Execute the method being tested
    $service = $this->makeService();
    $result = $service->doSomething('param1', 'param2');
    
    // ========== ASSERT ==========
    // Verify the results
    $this->assertTrue($result);
    $this->assertIsArray($result);
    $this->assertCount(1, $result);
}
```

