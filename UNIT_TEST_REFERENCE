# 🚀 Unit Test Quick Reference Card

## Struktur Dasar (Boilerplate)

```php
<?php
declare(strict_types=1);

namespace Tests\Unit\Usecases;

use PHPUnit\Framework\TestCase;
use Mockery;

/**
 * @coversDefaultClass \App\Usecases\MyUsecase
 */
class MyUsecaseTest extends TestCase
{
    private $dep1;
    private $dep2;

    protected function setUp(): void
    {
        parent::setUp();
        $this->dep1 = Mockery::mock(Dependency1::class);
        $this->dep2 = Mockery::mock(Dependency2::class);
    }

    protected function tearDown(): void
    {
        \Mockery::close();
        parent::tearDown();
    }

    protected function makeService()
    {
        return Mockery::mock(MyUsecase::class, [
            $this->dep1,
            $this->dep2,
        ])->makePartial();
    }
}
```

