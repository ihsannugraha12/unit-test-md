## Common Patterns

### Testing Exception

```php
public function testThrowsExceptionWhenInvalid()
{
    $this->expectException(InvalidArgumentException::class);
    $this->expectExceptionMessage('Invalid input');
    
    $this->repo->shouldReceive('find')->andReturn(null);
    
    $service = $this->makeService();
    $service->process('invalid_id');
}
```

### Testing Success Case

```php
public function testProcessReturnsSuccess()
{
    $expectedData = ['id' => 1, 'name' => 'Test'];
    
    $this->repo->shouldReceive('find')
        ->once()
        ->with(1)
        ->andReturn($expectedData);
    
    $service = $this->makeService();
    $result = $service->process(1);
    
    $this->assertTrue($result);
    $this->assertEquals($expectedData, $result);
}
```

### Testing with Multiple Scenarios (Data Provider)

```php
/**
 * @dataProvider processProvider
 */
public function testProcessWithVariousInputs($scenario, $input, $expected)
{
    if ($scenario === 'error') {
        $this->expectException(Exception::class);
        $this->repo->shouldReceive('find')->andReturn(null);
    } else {
        $this->repo->shouldReceive('find')->andReturn($expected);
    }
    
    $service = $this->makeService();
    $result = $service->process($input);
    
    if ($scenario !== 'error') {
        $this->assertEquals($expected, $result);
    }
}

public function processProvider()
{
    return [
        ['success', 1, ['id' => 1]],
        ['success', 2, ['id' => 2]],
        ['error', 0, null],
    ];
}
```

### Testing with Database Transaction

```php
public function testTransactionCommitOnSuccess()
{
    DB::shouldReceive('beginTransaction')->once();
    DB::shouldReceive('commit')->once();
    DB::shouldReceive('rollback')->never();
    
    $this->repo->shouldReceive('create')->once();
    
    $service = $this->makeService();
    $result = $service->create($data);
    
    $this->assertTrue($result);
}

public function testTransactionRollbackOnError()
{
    DB::shouldReceive('beginTransaction')->once();
    DB::shouldReceive('rollback')->once();
    DB::shouldReceive('commit')->never();
    
    $this->repo->shouldReceive('create')
        ->andThrow(new Exception('DB Error'));
    
    $this->expectException(Exception::class);
    
    $service = $this->makeService();
    $service->create($data);
}
```

### Testing Protected Methods

```php
public function testProtectedMethodBehavior()
{
    $service = $this->makeService();
    $service->shouldAllowMockingProtectedMethods();
    
    $service->shouldReceive('protectedMethod')
        ->once()
        ->andReturn($value);
    
    $result = $service->publicMethod();
    $this->assertEquals($value, $result);
}
```

